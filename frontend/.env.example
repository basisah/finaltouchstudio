# ==========================================
# Frontend Environment Variables
# ==========================================

# ------------------------------------------
# API Configuration
# ------------------------------------------
# In local development (with Docker), Vite proxies /api to the backend.
# However, when deployed to Vercel, you need to tell the frontend
# exactly where the backend API lives.
# 
# On Vercel, /api is handled by api/index.js (see root vercel.json).
# Leave unset or use /api for local dev (Vite proxy).

VITE_API_URL=/api

# ------------------------------------------
# Google OAuth Configuration
# ------------------------------------------
# Replace this with your Google Client ID from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

