{
  "installCommand": "npm ci && npm ci --prefix ../backend",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.cjs": {
      "maxDuration": 30,
      "includeFiles": "../backend/**"
    }
  }
}
